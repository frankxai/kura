{
  "name": "arcanea-threads",
  "version": "0.2.0",
  "private": true,
  "description": "Local-first Chrome extension that captures conversations, prompts and AI-generated media from every major AI platform into an Obsidian-compatible vault on disk. No cloud. No tracking.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "pnpm exec eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.37.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  },
  "license": "MIT",
  "author": "FrankX <frank@arcanea.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/arcanea-vault"
  },
  "keywords": [
    "chrome-extension",
    "obsidian",
    "second-brain",
    "ai-capture",
    "local-first",
    "chatgpt-export",
    "claude-export",
    "gemini-export",
    "grok-export",
    "deepseek-export",
    "perplexity-export",
    "knowledge-graph",
    "worldbuilding",
    "arcanea"
  ]
}
